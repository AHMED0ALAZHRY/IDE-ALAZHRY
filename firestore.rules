rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == "alazhryahmd006@gmail.com";
    }
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt']) &&
             data.uid is string &&
             data.email is string &&
             data.createdAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.uid == userId;
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.uid == resource.data.uid && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAdmin();
    }
    
    match /monuments/{monumentId} {
      allow read: if true; // Publicly readable for the app to function (guest mode)
      allow write: if isAdmin(); // Only admins can write
    }
    
    match /guides/{guideId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin();
    }
  }
}
