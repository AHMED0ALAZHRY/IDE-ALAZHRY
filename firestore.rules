rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isPrimaryAdmin() {
      return request.auth != null && request.auth.token.email == "alazhryahmd006@gmail.com";
    }

    function isAdmin() {
      return isPrimaryAdmin() || (request.auth != null && exists(/databases/$(database)/documents/supervisors/$(request.auth.token.email)));
    }
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt']) &&
             data.uid is string &&
             data.email is string &&
             data.createdAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /supervisors/{supervisorEmail} {
      // Primary admin can list all supervisors
      allow list: if isPrimaryAdmin();
      // Primary admin or the supervisor themselves can read the single document
      allow get: if isPrimaryAdmin() || (request.auth != null && request.auth.token.email == supervisorEmail);
      // Only primary admin can write
      allow write: if isPrimaryAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.uid == userId;
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.uid == resource.data.uid && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAdmin();
    }
    
    match /monuments/{monumentId} {
      allow read: if true; // Publicly readable for the app to function (guest mode)
      allow write: if isAdmin(); // Only admins can write
    }
    
    match /guides/{guideId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if (isAuthenticated() && request.resource.data.userId == request.auth.uid) || isAdmin();
      allow delete: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || (isAuthenticated() && request.resource.data.userId == request.auth.uid && request.resource.data.status == 'cancelled');
      allow delete: if isAdmin();
    }
  }
}
